"$schema" = 'https://starship.rs/config-schema.json'

# ==========================================
# 核心：根据 chezmoi 的 theme 变量自动切换调色板
# ==========================================
palette = "{{ index . "theme" | default "dark" }}"
add_newline = true

# ==========================================
# 布局格式
# ==========================================
format = """
[](color_bg)\
$os\
[╱ ](fg:color_fg bg:color_bg)\
$directory\
([╱ ](fg:color_fg bg:color_bg)$git_branch)\
$git_status\
[](fg:color_bg)\
$fill\
[](fg:color_bg)\
[ ](bg:color_bg)\
($status[╱ ](fg:color_fg bg:color_bg))\
($cmd_duration[╱ ](fg:color_fg bg:color_bg))\
($direnv[╱ ](fg:color_fg bg:color_bg))\
($package[╱ ](fg:color_fg bg:color_bg))\
($c[╱ ](fg:color_fg bg:color_bg))\
($cpp[╱ ](fg:color_fg bg:color_bg))\
($cmake[╱ ](fg:color_fg bg:color_bg))\
($conda[╱ ](fg:color_fg bg:color_bg))\
($container[╱ ](fg:color_fg bg:color_bg))\
($docker_context[╱ ](fg:color_fg bg:color_bg))\
($java[╱ ](fg:color_fg bg:color_bg))\
($lua[╱ ](fg:color_fg bg:color_bg))\
($nodejs[╱ ](fg:color_fg bg:color_bg))\
($python[╱ ](fg:color_fg bg:color_bg))\
($ruby[╱ ](fg:color_fg bg:color_bg))\
($rust[╱ ](fg:color_fg bg:color_bg))\
($username$hostname[╱ ](fg:color_fg bg:color_bg))\
$time\
([╱ ](fg:color_fg bg:color_bg)$battery)\
[](fg:color_bg)
$character\
"""

# ==========================================
# 亮色与暗色双调色板定义
# ==========================================
[palettes.dark]
color_bg = '236'
color_fg = '244'
color_dir = '39'
color_git = '76'
color_git_status = '246'
color_ok = '70'
color_err = '196'
color_warn = '178'
color_time = '66'
color_fill = '240'
color_os = '255'
color_blue = 'blue'
color_green = '149'
color_red = 'red'
color_yellow = 'yellow'
color_purple = '200'
color_user = '180'

[palettes.light]
# --- Tokyo Night Light 专属适配 ---
# 背景色：使用比终端背景稍微深一点的灰色/淡蓝色，产生层次感
color_bg = '#cfc9c2'      # Tokyo Night Light 的辅助背景色
color_fg = '#343b58'      # 经典的深蓝黑文字
color_dir = '#005f73'     # 青蓝色路径
color_git = '#485e30'     # 橄榄绿分支
color_git_status = '#8990b3' # 灰蓝色状态

# 状态与功能
color_ok = '#485e30'      # 成功
color_err = '#8c4351'     # 错误（深红）
color_warn = '#8f5e15'    # 警告（深橙）
color_time = '#565f89'    # 时间（灰紫）
color_fill = '#b4b5be'    # 分割线
color_os = '#343b58'      # OS 图标

# 基础色增强
color_blue = '#2e7de9'
color_green = '#587539'
color_red = '#f52a65'
color_yellow = '#8c6c3e'
color_purple = '#9854f1'
color_user = '#8f5e15'



# ==========================================
# 模块细节配置 (颜色已全部替换为变量)
# ==========================================
[cmd_duration]
min_time = 3000
format = '[$duration  ]($style)'
style = 'fg:color_fg bg:color_bg'

[status]
disabled = false
format = '[$symbol( $common_meaning)( $signal_name)( $signal_number)( $maybe_int) ]($style)'
style = 'bold fg:color_err bg:color_bg'
success_style = 'bold fg:color_ok bg:color_bg'
symbol = '✘'
map_symbol = false
pipestatus = true
pipestatus_format = '[$pipestatus]($style)'

[character]
success_symbol = '[❯](bold fg:color_ok)'
error_symbol = '[❯](bold fg:color_err)'
vimcmd_symbol = '[❮](bold fg:color_ok)'
vimcmd_replace_one_symbol = '[▶](bold fg:color_ok)'
vimcmd_replace_symbol = '[▶](bold fg:color_ok)'
vimcmd_visual_symbol = '[V](bold fg:color_ok)'

[time]
disabled = false
format = '[$time  ]($style)'
style = 'fg:color_time bg:color_bg'

[fill]
symbol = '─'
style = 'fg:color_fill'

[os]
format = '[ $symbol]($style)'
style = 'fg:color_os bg:color_bg'
disabled = false

[directory]
format ='[$read_only]($read_only_style)[ ](fg:color_dir bg:color_bg)[$path ]($style)'
style = 'fg:color_dir bg:color_bg'
read_only_style = 'bold fg:color_err bg:color_bg'
repo_root_format = '[$read_only]($read_only_style)[$before_root_path]($before_repo_root_style)[$repo_root]($repo_root_style)[$path ]($style)'
before_repo_root_style = 'bold fg:color_dir bg:color_bg'
repo_root_style = 'bold fg:color_dir bg:color_bg'
read_only = "󰌾 "
home_symbol = '~'
truncate_to_repo = false
fish_style_pwd_dir_length = 2

[git_branch]
format = '[$symbol$branch(:$remote_branch) ]($style)'
symbol = " "
style = 'bold fg:color_git bg:color_bg'

[git_status]
format = '([$all_status$ahead_behind]($style))'
style = 'bold fg:color_git_status bg:color_bg'
conflicted = '~${count} '
stashed = '*${count} '
ahead = '⇡${count} '
behind = '⇣${count} '
diverged = '⇠${behind_count} ⇢${ahead_count} '
untracked = '?${count} '
modified = '!${count} '
staged = '+${count} '
renamed = '»${count} '
deleted = '✘${count} '

[direnv]
format = '[$symbol$loaded/$allowed ]($style)'
style = 'bold fg:color_warn bg:color_bg'

[c]
format = '[$symbol($version(-$name) )]($style)'
style = 'bold fg:color_green bg:color_bg'
symbol = " "

[cpp]
format = '[$symbol($version(-$name) )]($style)'
style = 'bold fg:color_green bg:color_bg'
symbol = " "

[cmake]
format = '[$symbol($version )]($style)'
style = 'bold fg:color_blue bg:color_bg'
symbol = " "

[conda]
format = '[$symbol$environment ]($style)'
style = 'bold fg:color_green bg:color_bg'
symbol = " "

[container]
format = '[$symbol \[$name\] ]($style)'
style = 'bold dimmed fg:color_red bg:color_bg'

[docker_context]
format = '[$symbol$context ]($style)'
style = 'bold fg:color_blue bg:color_bg'
symbol = " "

[username]
format = '[$user]($style)'
style_root = 'bold fg:color_warn bg:color_bg'
style_user = 'fg:color_user bg:color_bg'

[hostname]
format = '[$ssh_symbol$hostname]($style)'
style = 'fg:color_user bg:color_bg'
ssh_symbol = '@'

[java]
format = '[${symbol}(${version} )]($style)'
style = 'dimmed fg:color_red bg:color_bg'
symbol = " "

[lua]
format = '[$symbol($version )]($style)'
style = 'bold fg:color_blue bg:color_bg'
symbol = " "

[nodejs]
format = '[$symbol($version )]($style)'
style = 'bold fg:color_red bg:color_bg'
symbol = " "

[os.symbols]
Alpaquita = " "
Alpine = " "
AlmaLinux = " "
Amazon = " "
Android = " "
Arch = " "
Artix = " "
CachyOS = " "
CentOS = " "
Debian = " "
DragonFly = " "
Emscripten = " "
EndeavourOS = " "
Fedora = " "
FreeBSD = " "
Garuda = "󰛓 "
Gentoo = " "
HardenedBSD = "󰞌 "
Illumos = "󰈸 "
Kali = " "
Linux = " "
Mabox = " "
Macos = " "
Manjaro = " "
Mariner = " "
MidnightBSD = " "
Mint = " "
NetBSD = " "
NixOS = " "
Nobara = " "
OpenBSD = "󰈺 "
openSUSE = " "
OracleLinux = "󰌷 "
Pop = " "
Raspbian = " "
Redhat = " "
RedHatEnterprise = " "
RockyLinux = " "
Redox = "󰀘 "
Solus = "󰠳 "
SUSE = " "
Ubuntu = " "
Unknown = " "
Void = " "
Windows = "󰍲 "

[package]
format = '[$symbol$version ]($style)'
style = 'bold fg:color_purple bg:color_bg'
symbol = "󰏗 "

[python]
format = '[${symbol}${pyenv_prefix}(${version} )(\($virtualenv\) )]($style)'
style = 'bold fg:color_yellow bg:color_bg'
symbol = " "

[ruby]
format = '[$symbol($version )]($style)'
style = 'bold fg:color_red bg:color_bg'
symbol = " "

[rust]
format = '[$symbol($version )]($style)'
style = 'bold fg:color_red bg:color_bg'
symbol = "󱘗 "

[battery]
format = '[$symbol ]($style)'
full_symbol = '[󰁹 $percentage](bold fg:color_ok bg:color_bg)'
unknown_symbol = '[󰂑 ](bold fg:color_fg bg:color_bg)'
empty_symbol = '[󰂎 $percentage](bold fg:color_err bg:color_bg)'

[[battery.display]]
threshold = 100
charging_symbol = '[󰁹 $percentage](bold fg:color_ok bg:color_bg)'
discharging_symbol = '[󰁹 $percentage](bold fg:color_warn bg:color_bg)'
style = 'bg:color_bg'

[[battery.display]]
threshold = 95
charging_symbol = '[󰂂 $percentage](bold fg:color_ok bg:color_bg)'
discharging_symbol = '[󰂂 $percentage](bold fg:color_warn bg:color_bg)'
style = 'bg:color_bg'

