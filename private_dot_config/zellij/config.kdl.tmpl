// ==========================================
// 1. 基础显示设置
// ==========================================
pane_frames false
default_layout "compact"
simplified_ui false

// ==========================================
// 2. 动态主题与颜色定义 (完全绑定，结构极简)
// ==========================================
{{- if eq .theme "light" }}
theme "custom-light"
themes {
    custom-light {
        fg "#343b58"
        bg "#e1e2e7"
        black "#a6b5d8"  // 你测试成功的那个浅灰蓝色
        red "#d24667"
        green "#437a4c"
        yellow "#8f5e15"
        blue "#2e7de9"
        magenta "#784bce"
        cyan "#0f4b6e"
        white "#ffffff"
        orange "#b25c0b"
    }
}
{{- else }}
theme "custom-dark"
themes {
    custom-dark {
        fg "#c0caf5"
        bg "#24283b"
        black "#1d202f"
        red "#f7768e"
        green "#9ece6a"
        yellow "#e0af68"
        blue "#7aa2f7"
        magenta "#bb9af7"
        cyan "#7dcfff"
        white "#a9b1d6"
        orange "#ff9e64"
    }
}
{{- end }}

// ==========================================
// 3. 快捷键 (完全按照成功测试的那次)
// ==========================================
keybinds {
    shared_except "locked" "pane" {
        bind "Ctrl w" { SwitchToMode "Pane"; }
    }
    
    pane {
        bind "h" { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "j" { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "k" { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "l" { MoveFocus "Right"; SwitchToMode "Normal"; }
        bind "Esc" { SwitchToMode "Normal"; }
    }
}
