local wezterm = require 'wezterm'
local config = wezterm.config_builder()

-- ==========================================
-- 1. 基础配置 (Tokyo Night + 极简主义)
-- ==========================================
config.color_scheme = 'Tokyo Night'
config.window_background_opacity = 0.85
config.macos_window_background_blur = 30
-- 修复红绿灯：RESIZE 能让顶部空间最稳固
config.window_decorations = "RESIZE" 
config.window_padding = { left = 20, right = 20, top = 15, bottom = 10 }

config.font = wezterm.font("JetBrainsMono Nerd Font")
config.font_size = 13.5

-- ==========================================
-- 2. 状态栏黑科技 (解决“看不见”和“报错”问题)
-- ==========================================
config.enable_tab_bar = true
config.use_fancy_tab_bar = false           -- 必须设为 false，否则右侧会被 Mac 系统层挡住
config.hide_tab_bar_if_only_one_tab = false -- 【核心修复】绝不隐藏，否则你看不到状态栏
config.tab_bar_at_bottom = false           -- 放在顶部，视角更自然

-- 模拟 sravioli 的路径缩短函数
local function shorten_path(cwd)
    if not cwd then return "" end
    cwd = cwd:gsub("^/Users/[^/]+", "~") -- 把 /Users/mimi 换成 ~
    -- 如果路径太长，只保留最后两级
    local parts = {}
    for part in string.gmatch(cwd, "[^/]+") do
        table.insert(parts, part)
    end
    if #parts > 3 then
        return ".../" .. parts[#parts-1] .. "/" .. parts[#parts]
    end
    return cwd
end

wezterm.on('update-status', function(window, pane)
    local cells = {}

    -- (1) 修复 is_zoomed 报错：必须先通过 pane 找到 tab
    local tab = pane:tab()
    if tab and tab:is_zoomed() then
        table.insert(cells, { Foreground = { Color = '#f7768e' } })
        table.insert(cells, { Attribute = { Intensity = 'Bold' } })
        table.insert(cells, { Text = ' 🔍 ZOOM ' })
    end

    -- (2) Leader 键状态 (Ctrl+a)
    if window:leader_active() then
        table.insert(cells, { Foreground = { Color = '#bb9af7' } })
        table.insert(cells, { Text = ' ⚡ LEADER ' })
    end

    -- (3) 响应式路径 (黑科技精髓)
    local cwd_uri = pane:get_current_working_dir()
    if cwd_uri then
        table.insert(cells, { Foreground = { Color = '#7aa2f7' } })
        table.insert(cells, { Text = ' 📂 ' .. shorten_path(cwd_uri.file_path) .. ' ' })
    end

    -- (4) 绿色时间
    table.insert(cells, { Foreground = { Color = '#9ece6a' } })
    table.insert(cells, { Text = ' 🕒 ' .. wezterm.strftime("%H:%M") .. ' ' })

    window:set_right_status(wezterm.format(cells))
end)

-- ==========================================
-- 3. 快捷键 (Alt 系列 + Leader 键)
-- ==========================================
config.leader = { key = 'a', mods = 'CTRL', timeout_milliseconds = 1000 }
config.keys = {
    -- 分屏 (Alt + d/e)
    { key = 'd', mods = 'ALT', action = wezterm.action.SplitVertical { domain = 'CurrentPaneDomain' } },
    { key = 'e', mods = 'ALT', action = wezterm.action.SplitHorizontal { domain = 'CurrentPaneDomain' } },
    -- 移动 (Alt + h/j/k/l)
    { key = 'h', mods = 'ALT', action = wezterm.action.ActivatePaneDirection 'Left' },
    { key = 'l', mods = 'ALT', action = wezterm.action.ActivatePaneDirection 'Right' },
    { key = 'k', mods = 'ALT', action = wezterm.action.ActivatePaneDirection 'Up' },
    { key = 'j', mods = 'ALT', action = wezterm.action.ActivatePaneDirection 'Down' },
    -- 缩放 (Alt + f)
    { key = 'f', mods = 'ALT', action = wezterm.action.TogglePaneZoomState },
}

return config
