# ==========================
# 核心体验优化 (你提供的完美底座)
# ==========================
# 1. 开启鼠标支持
set -g mouse on

# 修改前缀键为 Ctrl+a
set -g prefix C-a
unbind C-b
bind C-a send-prefix

# 2. 窗口和面板的序号从 1 开始
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

# 3. 解决 Vim 里按 ESC 键的延迟问题
set -s escape-time 0

# 4. 开启 256 色和 True Color 支持
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*256col*:Tc"

# ==========================
# 终极防卡顿/防延迟配置
# ==========================
# 5. 取消连续按键的等待时间
set -g repeat-time 0 


# ==========================
# 动态主题切换 (Chezmoi 接管)
# ==========================
{{- if eq (index . "theme" | default "dark") "light" }}
# --- Tokyo Night Light ---
# 1. 整体底色：融入终端背景色，消除边界感
set -g status-style bg="#e1e2e7",fg="#343b58"

# 2. 彻底重写左侧 Session (紫底白字，优雅的小标签)
set -g status-left "#[fg=#ffffff,bg=#9854f1,bold] ❐ #S #[bg=#e1e2e7]  "
set -g status-left-length 40

# 3. 彻底重写右侧 (极简时间，低调灰蓝)
set -g status-right "#[fg=#6172b0] %H:%M "

# 4. 未激活窗口 (去掉原本丑陋的深色背景，仅保留文字)
set -g window-status-format "#[fg=#6172b0,bg=#e1e2e7] #I:#W "

# 5. 当前激活窗口 (纯白背景块，亮蓝文字，营造悬浮高亮感)
set -g window-status-current-format "#[fg=#2e7de9,bg=#ffffff,bold]  #I:#W  "
set -g window-status-separator " "

# 6. 面板边框与提示
set -g pane-border-style fg="#c4c8d4"
set -g pane-active-border-style fg="#2e7de9"
set -g message-style bg="#ffffff",fg="#d24667",bold

{{- else }}
# --- Tokyo Night Dark ---
set -g status-style bg="#1d202f",fg="#c0caf5"

set -g status-left "#[fg=#1d202f,bg=#bb9af7,bold] ❐ #S #[bg=#1d202f]  "
set -g status-left-length 40
set -g status-right "#[fg=#565f89] %H:%M "

set -g window-status-format "#[fg=#565f89,bg=#1d202f] #I:#W "
set -g window-status-current-format "#[fg=#7aa2f7,bg=#24283b,bold]  #I:#W  "
set -g window-status-separator " "

set -g pane-border-style fg="#24283b"
set -g pane-active-border-style fg="#7aa2f7"
set -g message-style bg="#24283b",fg="#f7768e",bold
{{- end }}
