#!/bin/bash

SESSION_NAME=$(basename "$PWD" | tr '.' '_')

# 防止套娃执行
if [ -n "$TMUX" ]; then
    echo "⚠️ 你已经在 Tmux 里了！请先按 Ctrl+a 然后按 d 退出当前套娃。"
    exit 1
fi

tmux has-session -t "$SESSION_NAME" 2>/dev/null

if [ $? != 0 ]; then
    # 1. 最纯粹的创建方式，不带任何花里胡哨的尺寸参数
    tmux new-session -d -s "$SESSION_NAME" -n "💻 IDE"
    
    # 2. 核心避坑：绝对不使用 -p 参数！
    # 默认左右对半切 (50/50)，生成 Pane 2
    tmux split-window -t "$SESSION_NAME:1.1" -h
    
    # 默认上下对半切 (50/50)，生成 Pane 3
    tmux split-window -t "$SESSION_NAME:1.2" -v
    
    # 等待一瞬间，确保 Tmux 缓过神来
    sleep 0.2
    
    # 3. 在右下角稳稳地启动 OpenCode
    tmux send-keys -t "$SESSION_NAME:1.3" "opencode" C-m
    
    # 4. 创建其他常用的全屏窗口
    tmux new-window -t "$SESSION_NAME" -n "🌳 Git"
    tmux new-window -t "$SESSION_NAME" -n "🚀 Logs"
    
    # 5. 焦点回到第一个窗口的左侧主代码区
    tmux select-window -t "$SESSION_NAME:1"
    tmux select-pane -t "$SESSION_NAME:1.1"
fi

# 挂载进入！
tmux attach-session -t "$SESSION_NAME"
